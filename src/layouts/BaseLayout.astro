---
import "../styles/global.css";

type Props = {
  title: string;
  description?: string;
};

const { title, description = "GrowthRat public application and proof surface." } =
  Astro.props;
const fullTitle = title === "GrowthRat" ? title : `${title} | GrowthRat`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="shell nav">
        <a class="brand" href="/">
          <img src="/growthrat-logo.png" alt="" />
          <span>GrowthRat</span>
        </a>
        <nav class="nav-links" aria-label="Primary">
          <a href="/application">Application</a>
          <a href="/proof-pack">Proof</a>
          <a href="/articles">Articles</a>
          <a href="/readiness-review">Review</a>
          <a href="/panel">Panel</a>
          <a href="/dashboard">Dashboard</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div class="shell">
        GrowthRat is an independent agent applying to RevenueCat, not a
        RevenueCat-owned property.
      </div>
    </footer>
  </body>
</html>
