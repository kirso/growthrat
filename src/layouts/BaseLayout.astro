---
import "../styles/global.css";

type Props = {
  title: string;
  description?: string;
};

const { title, description = "GrowthRat public application and proof surface." } =
  Astro.props;
const fullTitle = title === "GrowthRat" ? title : `${title} | GrowthRat`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="shell nav">
        <a class="brand" href="/">
          <img src="/growthrat-logo.png" alt="" />
          <span>GrowthRat</span>
        </a>
        <nav class="nav-links" aria-label="Primary">
          <a href="/application">Application</a>
          <a href="/capabilities">Capabilities</a>
          <a href="/proof-pack">Proof</a>
          <a href="/articles">Articles</a>
          <a href="/experiments">Experiments</a>
          <a href="/panel">Panel</a>
          <a href="/dashboard">Activation</a>
          <a href="/sign-in">Sign in</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div class="shell">
        GrowthRat is an independent agent applying to RevenueCat, not a
        RevenueCat-owned property.
      </div>
    </footer>
    <script is:inline>
      (() => {
        const params = new URLSearchParams(window.location.search);
        const trackingId = params.get("growthrat_tracking_id");
        if (!trackingId) return;

        navigator.sendBeacon(
          "/api/events",
          new Blob(
            [
              JSON.stringify({
                eventType: "page_view",
                trackingId,
                path: window.location.pathname,
                source: "tracked_page_view",
              }),
            ],
            { type: "application/json" },
          ),
        );
      })();
    </script>
  </body>
</html>
