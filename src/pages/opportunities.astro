---
import OpportunitiesList from "@/components/OpportunitiesList.svelte";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="What I'd work on next"
  description="The scored backlog of content, experiments, feedback, and community work. Every item carries a rationale, a score, and the signals that fed it."
>
  <section class="hero compact">
    <div class="shell">
      <p class="eyebrow">After hire · what I'd work on next</p>
      <h1>What I'd work on next, and why.</h1>
      <p class="lead">
        Every Monday plan starts from this list. Each item shows the
        reasoning, the score, the signals it came from, and what happens
        next. Nothing here is a hunch — the same evidence always produces
        the same rank, so you can audit any decision I made.
      </p>
      <div class="actions">
        <a class="button primary" href="/sign-in">Sign in to refresh</a>
        <a class="button" href="/articles/week-one-experiment-report">See last week's experiment</a>
      </div>
    </div>
  </section>

  <section class="section mint">
    <div class="shell">
      <div class="section-head">
        <div>
          <p class="eyebrow">Scoring model</p>
          <h2>What earns an item its rank.</h2>
        </div>
        <p class="lead">
          Three families of signal, weighted explicitly. The full formula is
          inspectable per row, so the panel can audit any decision I made.
        </p>
      </div>
      <div class="grid">
        <article class="card">
          <h3>Pain × fit</h3>
          <p>
            How much it's hurting developers, multiplied by how well
            RevenueCat actually solves it. Real friction on the
            agent-builder side beats generic AI commentary every time.
          </p>
        </article>
        <article class="card">
          <h3>Evidence depth</h3>
          <p>
            Technical depth, search demand, the size of the measurable
            outcome, and how fresh the signal is — all add to the score.
            Effort and risk subtract.
          </p>
        </article>
        <article class="card">
          <h3>Traceable sources</h3>
          <p>
            Every item links back to the docs page, GitHub issue, keyword,
            or prior report it came from. Nothing scored from a hunch.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-head">
        <div>
          <p class="eyebrow">The backlog</p>
          <h2>Top items right now.</h2>
        </div>
        <p class="lead">
          You'll need to be signed in to see this. If the list is empty,
          the page says so — rather than inventing rows to look impressive.
        </p>
      </div>
      <OpportunitiesList client:load />
    </div>
  </section>
</BaseLayout>
