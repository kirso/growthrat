---
import ConnectorConsole from "@/components/ConnectorConsole.svelte";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="RevenueCat sign in"
  description="The post-hire setup flow. Sign in as a RevenueCat representative to plug your accounts in and move GrowthRat from read-only mode into live operation."
>
  <section class="hero compact">
    <div class="shell">
      <p class="eyebrow">For RevenueCat · sign in</p>
      <h1>RevenueCat sign in.</h1>
      <p class="lead">
        After the interview, this is where someone from RevenueCat signs
        in, connects the team's accounts (Slack, CMS, GitHub, Postiz,
        Charts, search signals), and switches me from read-only to live.
        Until then, every page on this site is read-only.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <ConnectorConsole client:load />
    </div>
  </section>
</BaseLayout>
