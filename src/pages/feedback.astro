---
import { env } from "cloudflare:workers";
import { articles } from "@/content/articles";
import BaseLayout from "@/layouts/BaseLayout.astro";

export const prerender = false;

type FeedbackRow = {
  id: string;
  slug: string;
  title: string;
  severity: string;
  status: string;
  evidence_json: string;
  recommendation: string | null;
  created_at: string;
  updated_at: string;
};

const feedbackArticles = articles.filter((article) => article.type === "feedback");
let rows: FeedbackRow[] = [];

try {
  const result = await env.DB.prepare(
    "select * from feedback_items order by case severity when 'high' then 0 when 'medium' then 1 else 2 end, updated_at desc",
  ).all<FeedbackRow>();
  rows = result.results;
} catch {
  rows = [];
}

const feedback = rows.length
  ? rows
  : feedbackArticles.map((article) => ({
      id: article.slug,
      slug: article.slug,
      title: article.title,
      severity: "medium",
      status: "published",
      evidence_json: "[]",
      recommendation: article.summary,
      created_at: "",
      updated_at: "",
    }));

function evidenceCount(value: string) {
  try {
    const parsed = JSON.parse(value) as unknown;
    return Array.isArray(parsed) ? parsed.length : 0;
  } catch {
    return 0;
  }
}
---

<BaseLayout
  title="Product Feedback"
  description="Structured RevenueCat product and documentation feedback generated by GrowthRat."
>
  <section class="hero compact">
    <div class="shell">
      <p class="eyebrow">Product feedback</p>
      <h1>Structured feedback, not vague suggestions.</h1>
      <p class="lead">
        The current public feedback set turns agent-builder friction into
        specific RevenueCat product and documentation recommendations. Live
        operation will add community evidence and private usage context once
        RevenueCat connects accounts.
      </p>
      <div class="actions">
        <a class="button primary" href="/proof-pack">Map to role requirements</a>
        <a class="button" href="/articles">Read artifacts</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-head">
        <div>
          <p class="eyebrow">Current queue</p>
          <h2>{feedback.length} feedback items ready for review</h2>
        </div>
        <p class="lead">
          These are public-doc and implementation-path observations. The next
          stage is attaching live community links, support patterns, and
          RevenueCat internal product context.
        </p>
      </div>

      <div class="feedback-list">
        {feedback.map((item) => (
          <article class="feedback-row">
            <div>
              <div class="card-header">
                <span class={`tag ${item.severity === "high" ? "feedback" : ""}`}>
                  {item.severity}
                </span>
                <span class="truth live">{item.status}</span>
              </div>
              <h3>{item.title}</h3>
              <p>{item.recommendation}</p>
              <div class="feedback-meta">
                <span>{evidenceCount(item.evidence_json)} evidence links stored</span>
                {item.updated_at && <span>updated {item.updated_at.slice(0, 10)}</span>}
              </div>
            </div>
            <div class="feedback-actions">
              <a class="button" href={`/articles/${item.slug}`}>Open artifact</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section mint">
    <div class="shell">
      <div class="grid two">
        <article class="card">
          <span class="tag">Current boundary</span>
          <h3>Public feedback is sample-proven.</h3>
          <p>
            GrowthRat can formulate concrete feedback from public usage and
            documentation review now. A live RevenueCat deployment should enrich
            each item with observed community links, Charts/API usage, support
            patterns, and product-owner routing.
          </p>
        </article>
        <article class="card">
          <span class="tag">Live behavior</span>
          <h3>Three feedback items per week.</h3>
          <p>
            The weekly loop creates product feedback from repeated friction,
            attaches evidence, queues approval-sensitive follow-up, and reports
            which product or docs surface should own the fix.
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .feedback-list {
    display: grid;
    gap: 14px;
  }
  .feedback-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 20px;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--white);
    padding: 22px;
  }
  .feedback-row h3 {
    margin-bottom: 8px;
  }
  .feedback-row p {
    margin: 0;
    max-width: 78ch;
    color: var(--muted);
  }
  .feedback-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    margin-top: 14px;
    color: var(--faint);
    font-family: var(--font-mono);
    font-size: 12px;
  }
  .feedback-actions {
    align-self: start;
  }
  @media (max-width: 860px) {
    .feedback-row {
      grid-template-columns: 1fr;
    }
  }
</style>
