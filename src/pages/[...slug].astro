---
import { getArticle } from "@/content/articles";
import { getPage } from "@/content/pages";
import RuntimeStatus from "@/components/RuntimeStatus.svelte";
import BaseLayout from "@/layouts/BaseLayout.astro";

const slug = Astro.params.slug ?? "";
const articleSlug = slug.startsWith("articles/") ? slug.replace("articles/", "") : "";
const article = articleSlug ? getArticle(articleSlug) : undefined;
const page = article ? undefined : getPage(slug);
const showRuntimeStatus =
  !article && page && ["dashboard", "go-live", "pipeline", "interview-truth"].includes(page.slug);

if (!article && !page) {
  return Astro.redirect("/");
}

const articleResponsibility = (type: string) => {
  switch (type) {
    case "technical": return "Publish technical content";
    case "feedback": return "Submit structured product feedback";
    case "experiment": return "Run growth experiments";
    case "report": return "Report weekly";
    default: return "Public artifact";
  }
};
---

<BaseLayout
  title={article?.title ?? page!.title}
  description={article?.summary ?? page!.summary}
>
  <section class="hero compact">
    <div class="shell">
      <p class="eyebrow">{article ? article.type : page!.eyebrow}</p>
      <h1>{article?.title ?? page!.title}</h1>
      <p class="lead">{article?.summary ?? page!.summary}</p>
      {article && (
        <div class="article-meta">
          <span class={`tag ${article.type}`}>{article.type}</span>
          <span class="truth live">live</span>
          <span class="dot"></span>
          <span>Maps to: {articleResponsibility(article.type)}</span>
          <span class="dot"></span>
          <span>Source: {article.sourcePath}</span>
        </div>
      )}
      {article && (
        <div class="actions">
          <a class="button" href="/articles">← All artifacts</a>
          <a class="button ghost" href="/proof-pack">Proof pack →</a>
        </div>
      )}
    </div>
  </section>

  {showRuntimeStatus && (
    <section class="section">
      <div class="shell">
        <RuntimeStatus client:load />
      </div>
    </section>
  )}

  {article ? (
    <section class="section">
      <div class="shell prose">
        {article.body.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </section>
  ) : (
    page!.sections.map((section, index) => {
      const tone = ["", "mint", "", "lavender"][index % 4];
      return (
        <section class={`section ${tone}`}>
          <div class="shell prose">
            <h2>{section.title}</h2>
            {section.body.length > 3 ? (
              <ul>
                {section.body.map((item) => <li>{item}</li>)}
              </ul>
            ) : (
              section.body.map((paragraph) => <p>{paragraph}</p>)
            )}
          </div>
        </section>
      );
    })
  )}
</BaseLayout>
