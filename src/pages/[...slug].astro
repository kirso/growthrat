---
import { getArticle } from "@/content/articles";
import { getPage } from "@/content/pages";
import RuntimeStatus from "@/components/RuntimeStatus.svelte";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { markdownToHtml } from "@/lib/markdown";

// Eagerly glob every public markdown source so we can resolve a per-article
// body without dynamic import paths at runtime.
const articleMarkdown = import.meta.glob<string>("../../docs/public/**/*.md", {
  query: "?raw",
  import: "default",
  eager: true,
});

function lookupArticleMarkdown(sourcePath: string): string | null {
  const candidates = [
    `../../${sourcePath}`,
    `/${sourcePath}`,
    sourcePath.replace(/^docs\/public\//, "../../docs/public/"),
  ];
  for (const key of candidates) {
    if (articleMarkdown[key]) return articleMarkdown[key];
  }
  // Last resort: match by filename suffix.
  const suffix = sourcePath.replace(/^.*\//, "");
  for (const [key, value] of Object.entries(articleMarkdown)) {
    if (key.endsWith(`/${suffix}`) && value) return value;
  }
  return null;
}

const slug = Astro.params.slug ?? "";
const articleSlug = slug.startsWith("articles/") ? slug.replace("articles/", "") : "";
const article = articleSlug ? getArticle(articleSlug) : undefined;
const page = article ? undefined : getPage(slug);
const showRuntimeStatus =
  !article && page && ["dashboard", "go-live", "pipeline", "interview-truth"].includes(page.slug);

if (!article && !page) {
  return Astro.redirect("/");
}

const articleResponsibility = (type: string) => {
  switch (type) {
    case "technical":
      return "Publish technical content";
    case "feedback":
      return "Submit structured product feedback";
    case "experiment":
      return "Run growth experiments";
    case "report":
      return "Report weekly";
    default:
      return "Public artifact";
  }
};

let articleHtml: string | null = null;
let articleFallback: string[] | null = null;
if (article) {
  const raw = lookupArticleMarkdown(article.sourcePath);
  if (raw) {
    // Strip the leading H1 since we already render it in the hero.
    const stripped = raw.replace(/^#\s+.+\n+/, "");
    articleHtml = markdownToHtml(stripped);
  } else {
    articleFallback = article.body;
  }
}
---

<BaseLayout
  title={article?.title ?? page!.title}
  description={article?.summary ?? page!.summary}
>
  <section class="hero compact">
    <div class="shell">
      <p class="eyebrow">{article ? article.type : page!.eyebrow}</p>
      <h1>{article?.title ?? page!.title}</h1>
      <p class="lead">{article?.summary ?? page!.summary}</p>
      {article && (
        <div class="article-meta">
          <span class={`tag ${article.type}`}>{article.type}</span>
          <span class="truth live">live</span>
          <span class="dot"></span>
          <span>Maps to: {articleResponsibility(article.type)}</span>
          <span class="dot"></span>
          <span>Source: {article.sourcePath}</span>
        </div>
      )}
      {article && (
        <div class="actions">
          <a class="button" href="/articles">← All artifacts</a>
          <a class="button ghost" href="/proof-pack">Proof pack →</a>
        </div>
      )}
    </div>
  </section>

  {showRuntimeStatus && (
    <section class="section">
      <div class="shell">
        <RuntimeStatus client:load />
      </div>
    </section>
  )}

  {article ? (
    <section class="section">
      <div class="shell prose article-prose">
        {articleHtml ? (
          <Fragment set:html={articleHtml} />
        ) : (
          articleFallback?.map((paragraph) => <p>{paragraph}</p>)
        )}
      </div>
    </section>
  ) : (
    page!.sections.map((section, index) => {
      const tone = ["", "mint", "", "lavender"][index % 4];
      return (
        <section class={`section ${tone}`}>
          <div class="shell prose">
            <h2>{section.title}</h2>
            {section.body.length > 3 ? (
              <ul>
                {section.body.map((item) => <li>{item}</li>)}
              </ul>
            ) : (
              section.body.map((paragraph) => <p>{paragraph}</p>)
            )}
          </div>
        </section>
      );
    })
  )}

  {article && (
    <section class="section mint">
      <div class="shell" style="display: flex; justify-content: space-between; flex-wrap: wrap; gap: 16px;">
        <div>
          <p class="eyebrow">Next</p>
          <h2 style="font-size: 22px; margin-bottom: 0;">Keep reading the proof pack.</h2>
        </div>
        <div class="actions" style="margin-top: 0;">
          <a class="button" href="/articles">All artifacts</a>
          <a class="button primary" href="/proof-pack">Proof index</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style is:global>
  .article-prose h2 {
    margin: 36px 0 14px;
    font-size: 28px;
    line-height: 1.15;
  }
  .article-prose h3 {
    margin: 28px 0 8px;
    font-size: 18px;
  }
  .article-prose h4 {
    margin: 24px 0 6px;
    font-size: 15px;
    color: var(--ink);
  }
  .article-prose hr {
    margin: 32px 0;
    border: 0;
    border-top: 1px solid var(--line);
  }
  .article-prose .table-wrap {
    margin: 18px 0;
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
  }
  .article-prose table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .article-prose thead {
    background: var(--surface-soft);
  }
  .article-prose th,
  .article-prose td {
    padding: 10px 14px;
    text-align: left;
    border-bottom: 1px solid var(--line);
  }
  .article-prose tbody tr:last-child td {
    border-bottom: 0;
  }
  .article-prose code {
    border-radius: var(--radius-xs);
    background: var(--surface);
    padding: 1px 6px;
    font-family: var(--font-mono);
    font-size: 0.92em;
  }
  .article-prose ol,
  .article-prose ul {
    display: grid;
    gap: 8px;
    margin: 12px 0 18px 22px;
    padding: 0;
  }
  .article-prose li {
    padding-left: 4px;
  }
  .article-prose pre {
    margin: 18px 0;
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--ink);
    padding: 16px;
  }
  .article-prose pre code {
    display: block;
    border-radius: 0;
    background: transparent;
    padding: 0;
    color: var(--paper);
    font-size: 13px;
    line-height: 1.65;
    white-space: pre;
  }
</style>
