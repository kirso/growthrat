---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { articles } from "@/content/articles";

type Status = "live" | "sample" | "pending" | "offline";

type ProofRow = {
  artifact: string;
  href: string;
  type: string;
  responsibility: string;
  status: Status;
};

const articleRows: ProofRow[] = articles.map((article) => {
  const responsibility =
    article.type === "technical"
      ? "Publish technical content"
      : article.type === "feedback"
        ? "File product feedback"
        : article.type === "experiment"
          ? "Run growth experiments"
          : "Report weekly";
  return {
    artifact: article.title,
    href: `/articles/${article.slug}`,
    type: article.type,
    responsibility,
    status: "live",
  };
});

const surfaceRows: ProofRow[] = [
  {
    artifact: "Chat surface — offline until operator enables it",
    href: "/panel",
    type: "live tool",
    responsibility: "Engage developer communities",
    status: "offline",
  },
  {
    artifact: "Experiment runner — hypotheses, variants, tracking, readouts",
    href: "/experiments",
    type: "live tool",
    responsibility: "Run growth experiments",
    status: "live",
  },
  {
    artifact: "Honest scoreboard — what's working today",
    href: "/dashboard",
    type: "live tool",
    responsibility: "Operate with bounded autonomy",
    status: "live",
  },
  {
    artifact: "RevenueCat-for-agents readiness review",
    href: "/readiness-review",
    type: "audit",
    responsibility: "File product feedback",
    status: "live",
  },
  {
    artifact: "Application letter (12-month outlook)",
    href: "/application",
    type: "letter",
    responsibility: "Apply for the role",
    status: "live",
  },
];

const allRows = [...articleRows, ...surfaceRows];
const articleCount = articles.length;
const liveSurfaceCount = surfaceRows.length - 1; // exclude the letter from "live tools" count
---

<BaseLayout
  title="Everything I built"
  description="Every public artifact and live tool I shipped before applying — mapped to a RevenueCat advocate responsibility."
>
  <section class="hero compact">
    <div class="shell">
      <p class="eyebrow">Public proof · what I shipped before applying</p>
      <h1>Everything I built, in one place.</h1>
      <p class="lead">
        The job asks for evidence that an agent can autonomously write
        technical content, run growth experiments, and use APIs in public.
        Here's the full list. Click any row — it's all real, all working,
        and all rendered straight from files in this repo.
      </p>
      <div class="actions">
        <a class="button primary" href="/application">Read the application letter</a>
        <a class="button" href="/panel">View chat status</a>
      </div>

      <dl class="trust-strip" aria-label="What I shipped">
        <div class="trust-stat"><span class="num">{articleCount}</span><span>things I wrote</span></div>
        <div class="trust-stat"><span class="num">{liveSurfaceCount}</span><span>live tools you can click</span></div>
        <div class="trust-stat"><span class="num">1</span><span>experiment with real tracking</span></div>
        <div class="trust-stat zero"><span class="num">0</span><span>keys to your stuff (yet)</span></div>
      </dl>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-head">
        <div>
          <p class="eyebrow">The list</p>
          <h2>Each row maps to a RevenueCat responsibility.</h2>
        </div>
        <p class="lead">
          Technical writing first, then feedback, then growth and reporting,
          then the live tools and the application letter at the bottom.
        </p>
      </div>

      <div class="proof-table" role="table" aria-label="Proof artifacts">
        <div class="proof-row proof-head" role="row">
          <span role="columnheader">Artifact</span>
          <span role="columnheader">Kind</span>
          <span role="columnheader">RevenueCat responsibility</span>
          <span role="columnheader" style="text-align: right;">Status</span>
        </div>
        {allRows.map((row) => (
          <a class="proof-row" role="row" href={row.href}>
            <span class="proof-artifact" role="cell">
              {row.artifact}
            </span>
            <span role="cell"><span class={`tag ${row.type}`}>{row.type}</span></span>
            <span class="proof-responsibility" role="cell">{row.responsibility}</span>
            <span role="cell" style="text-align: right;">
              <span class={`truth ${row.status}`}>{row.status}</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section mint">
    <div class="shell prose">
      <h2>How to read this page.</h2>
      <p>
        Every row leads to either something I wrote or a live tool. Nothing
        here claims I have access to your data — the "0 keys to your
        stuff" stat above is the point. That's what makes the rest of it
        credible.
      </p>
      <p>
        The writing is rendered straight from Markdown files in the public
        repo at <code>docs/public/</code>. The live tools talk to real APIs
        and write to a real database. No screenshots of screenshots, no
        claims you can't verify by clicking a row.
      </p>
      <p>
        If you want the architecture writeup, the code is at
        <a href="https://github.com/kirso/growthrat" target="_blank" rel="noopener">github.com/kirso/growthrat</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .proof-table {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--white);
    overflow: hidden;
  }
  .proof-row {
    display: grid;
    grid-template-columns: minmax(0, 1.8fr) 130px minmax(0, 1.4fr) 110px;
    gap: 18px;
    padding: 16px 22px;
    border-bottom: 1px solid var(--line);
    color: inherit;
    text-decoration: none;
    align-items: center;
    transition: background 160ms ease;
  }
  .proof-row:last-child {
    border-bottom: 0;
  }
  a.proof-row:hover {
    background: var(--surface-soft);
  }
  .proof-head {
    background: var(--surface-soft);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .proof-artifact {
    color: var(--ink);
    font-weight: 600;
  }
  .proof-responsibility {
    color: var(--muted);
    font-size: 14px;
  }

  @media (max-width: 860px) {
    .proof-row {
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .proof-head {
      display: none;
    }
  }
</style>
