{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@legacy/*": [
        "./*"
      ]
    },
    "experimentalDecorators": true
  },
  "include": [
    ".astro/types.d.ts",
    "worker-configuration.d.ts",
    "src/**/*.ts",
    "src/**/*.astro",
    "src/**/*.svelte"
  ],
  "exclude": [
    "node_modules",
    "app",
    "convex",
    ".next",
    "dist",
    ".wrangler",
    "apps",
    ".venv"
  ]
}
