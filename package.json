{
  "name": "growthcat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:convex": "bunx convex dev",
    "dev:inngest": "bunx inngest-cli@latest dev",
    "dev:all": "concurrently \"bun run dev\" \"bun run dev:convex\" \"bun run dev:inngest\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "bunx vercel deploy --prod"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/openai": "^1.3.0",
    "@convex-dev/agent": "^0.3.0",
    "@inngest/agent-kit": "^0.5.0",
    "@slack/web-api": "^7.9.0",
    "@tailwindcss/postcss": "^4.2.1",
    "ai": "^4.3.0",
    "concurrently": "^9.1.0",
    "convex": "^1.21.0",
    "inngest": "^3.30.0",
    "next": "15.3.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.16.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.31.0",
    "eslint-config-next": "^15.3.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
