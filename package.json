{
  "name": "growthrat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "astro check && astro build",
    "preview": "astro preview --host 0.0.0.0",
    "lint": "eslint .",
    "typecheck": "astro check && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf:types": "WRANGLER_LOG_PATH=/tmp/wrangler.log wrangler types --env-file wrangler-types.env",
    "cf:check": "WRANGLER_LOG_PATH=/tmp/wrangler.log wrangler deploy --dry-run",
    "deploy": "astro build && WRANGLER_LOG_PATH=/tmp/wrangler.log wrangler deploy --keep-vars"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/provider-utils": "^4.0.19",
    "@astrojs/cloudflare": "^13.3.1",
    "@astrojs/svelte": "^8.1.0",
    "agents": "^0.12.3",
    "ai": "^6.0.116",
    "astro": "^6.2.2",
    "sharp": "^0.34.5",
    "svelte": "^5.55.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@types/node": "^22.16.0",
    "eslint": "^9.31.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.88.0"
  }
}
