# =============================================================================
# GrowthCat Environment Variables
# Copy to .env.local: cp .env.example .env.local
# =============================================================================

# ┌─────────────────────────────────────────────────────────────────────────────
# │ TIER 1: Makes the product work (set up first)
# └─────────────────────────────────────────────────────────────────────────────

# Convex — the database + crons + real-time queries
# Run: npx convex dev (creates project, prints URL)
# Dashboard: https://dashboard.convex.dev
NEXT_PUBLIC_CONVEX_URL=

# Anthropic — LLM for content generation + panel console streaming
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Inngest — agent orchestration + scheduled functions
# Local dev: npx inngest-cli@latest dev (no keys needed locally)
# Cloud: https://app.inngest.com (keys needed for production only)
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# ┌─────────────────────────────────────────────────────────────────────────────
# │ TIER 2: Makes distribution work
# └─────────────────────────────────────────────────────────────────────────────

# Typefully — posts to X + LinkedIn + Threads + Bluesky + Mastodon
# Get key: https://typefully.com/settings/api
# Social set ID: call typefully_list_social_sets to find yours
TYPEFULLY_API_KEY=
TYPEFULLY_SOCIAL_SET_ID=

# Slack — weekly reports + team communication
# Create app: https://api.slack.com/apps
# Scopes: chat:write, files:write, channels:read
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=growthcat

# GitHub — gists, issue comments, public code artifacts
# Create token: https://github.com/settings/tokens
# Scopes: gist, public_repo
GITHUB_TOKEN=

# ┌─────────────────────────────────────────────────────────────────────────────
# │ TIER 3: Makes growth intelligence work
# └─────────────────────────────────────────────────────────────────────────────

# DataForSEO — keyword research + SERP analysis + content strategy
# Get credentials: https://app.dataforseo.com/api-dashboard
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ┌─────────────────────────────────────────────────────────────────────────────
# │ SECURITY: Internal auth tokens
# └─────────────────────────────────────────────────────────────────────────────

# Shared secret between Inngest functions and Convex HTTP endpoints
# Generate: openssl rand -hex 32
GROWTHCAT_INTERNAL_SECRET=

# Token for panel console SSE endpoint (prevents unauthorized LLM usage)
# Generate: openssl rand -hex 16
# Leave empty to allow unauthenticated panel access (dev only)
GROWTHCAT_PANEL_TOKEN=

# Slack request verification
SLACK_SIGNING_SECRET=

# ┌─────────────────────────────────────────────────────────────────────────────
# │ OPTIONAL: Only needed in specific cases
# └─────────────────────────────────────────────────────────────────────────────

# OpenAI — fallback LLM (only if Anthropic is unavailable)
# OPENAI_API_KEY=

# RevenueCat — only needed post-hire when RC provides access
# REVENUECAT_API_KEY=
# REVENUECAT_PROJECT_ID=

# Convex deploy key — only for production CI/CD
# CONVEX_DEPLOY_KEY=
