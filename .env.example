# =============================================================================
# GrowthRat Environment Variables
# Copy to .env.local or .dev.vars for local Cloudflare development.
# =============================================================================
#
# OWNERSHIP MODEL:
#   OPERATOR runs the proof Cloudflare deployment until RC activation.
#
#   REVENUECAT connects after interview approval:
#   RevenueCat API/Charts, Slack, Blog CMS, GitHub org, Postiz social,
#   keyword/community providers, and other channel accounts from the in-app
#   connected-account flow.
#
# =============================================================================

# -----------------------------------------------------------------------------
# ACTIVE CLOUDFLARE RUNTIME
# -----------------------------------------------------------------------------

APP_MODE=interview_proof
AI_GATEWAY_ID=growthrat
AI_CHAT_MODEL=@cf/meta/llama-3.2-3b-instruct
AI_DAILY_CALL_LIMIT=120
CHAT_DAILY_LIMIT=80
KILL_SWITCH=false
MAX_AI_OUTPUT_TOKENS=500
MAX_CHAT_MESSAGE_CHARS=1200
MODEL_CHAT_ENABLED=true
PUBLIC_EVENT_DAILY_LIMIT=5000
PUBLIC_SITE_URL=http://127.0.0.1:4321
REVENUECAT_ROLE=agentic-ai-growth-advocate

# Activation code for the first RevenueCat representative session and fallback
# CLI/API auth. Required before enabling side effects. Generate:
# openssl rand -hex 32
GROWTHRAT_INTERNAL_SECRET=

# Encrypt RC-provided connected-account tokens before storing them in D1.
# Generate: openssl rand -base64 32
GROWTHRAT_CONNECTOR_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# LOCAL PROOF FALLBACKS ONLY
# -----------------------------------------------------------------------------
#
# In production rc_live, these values should be provided by a signed-in
# RevenueCat representative through connected-account onboarding, not by editing
# deployment env vars.

# RevenueCat API access
REVENUECAT_API_KEY=
REVENUECAT_PROJECT_ID=

# DataForSEO - keyword research, SERP analysis, experiment baselines
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# X/Twitter - local proof fallback for community monitoring only
X_BEARER_TOKEN=

# Postiz - multi-platform social distribution
POSTIZ_API_KEY=
# Optional. Use the cloud URL by default, or point at a self-hosted Postiz API.
POSTIZ_API_BASE_URL=https://api.postiz.com/public/v1

# GrowthRat GitHub account - content backup, community engagement
GITHUB_TOKEN=
GITHUB_OWNER=kirso
GITHUB_CONTENT_REPO=growthrat

# Slack connector
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=growthrat

# Blog/CMS publishing connector
CMS_API_TOKEN=

# -----------------------------------------------------------------------------
# REVENUECAT CONNECTS
# -----------------------------------------------------------------------------
#
# These are post-hire connector values supplied through the app by authorized
# RevenueCat representatives. They are shown here only as names/concepts, not
# as env vars to set for production rc_live.
#
# RC_SLACK_BOT_TOKEN
# RC_CMS_API_KEY
# RC_CHARTS_API_KEY
# RC_GITHUB_ORG
# RC_REPORT_CHANNEL
# RC_REVIEW_MODE
# RC_FOCUS_TOPICS
