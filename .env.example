# =============================================================================
# GrowthRat Environment Variables
# Copy to .env.local or .dev.vars for local Cloudflare development.
# =============================================================================
#
# OWNERSHIP MODEL:
#   OPERATOR pays for: Cloudflare, Anthropic, DataForSEO, Typefully, Voyage
#   (covered by RC's "dedicated budget for compute resources and API access")
#
#   REVENUECAT connects: Slack, Blog CMS, Charts API, GitHub org
#   (via post-hire connector onboarding)
#
# =============================================================================

# -----------------------------------------------------------------------------
# ACTIVE CLOUDFLARE RUNTIME
# -----------------------------------------------------------------------------

APP_MODE=interview_proof
AI_GATEWAY_ID=growthrat
PUBLIC_SITE_URL=http://127.0.0.1:4321
REVENUECAT_ROLE=agentic-ai-growth-advocate

# Internal auth. Required before enabling side effects or authenticated operator
# actions. Generate: openssl rand -hex 32
GROWTHRAT_INTERNAL_SECRET=

# Anthropic - LLM for chat, panel console, content generation
ANTHROPIC_API_KEY=

# OpenAI fallback and AI Gateway-compatible provider key
OPENAI_API_KEY=

# RevenueCat API access after RevenueCat activation
REVENUECAT_API_KEY=
REVENUECAT_PROJECT_ID=

# Voyage AI - embeddings for retrieval experiments
VOYAGE_API_KEY=

# DataForSEO - keyword research, SERP analysis, experiment baselines
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Typefully - multi-platform social distribution
TYPEFULLY_API_KEY=
TYPEFULLY_SOCIAL_SET_ID=

# GrowthRat GitHub account - content backup, community engagement
GITHUB_TOKEN=
GITHUB_OWNER=kirso
GITHUB_CONTENT_REPO=growthrat

# Slack connector
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=growthrat

# -----------------------------------------------------------------------------
# REVENUECAT CONNECTS
# -----------------------------------------------------------------------------
#
# These are post-hire connector values, ideally stored as Cloudflare secrets or
# connector records, not committed to local files.
#
# RC_SLACK_BOT_TOKEN
# RC_CMS_API_KEY
# RC_CHARTS_API_KEY
# RC_GITHUB_ORG
# RC_REPORT_CHANNEL
# RC_REVIEW_MODE
# RC_FOCUS_TOPICS
