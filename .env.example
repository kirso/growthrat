# =============================================================================
# GrowthRat Environment Variables
# Copy to .env.local: cp .env.example .env.local
# =============================================================================
#
# OWNERSHIP MODEL:
#   OPERATOR pays for: Anthropic, DataForSEO, Convex, Vercel, Typefully, Voyage
#   (covered by RC's "dedicated budget for compute resources and API access")
#
#   REVENUECAT connects: Slack, Blog CMS, Charts API, GitHub org
#   (via self-service onboarding at /onboarding — keys stored server-side)
#
# =============================================================================

# ┌─────────────────────────────────────────────────────────────────────────────
# │ OPERATOR INFRASTRUCTURE (we pay, we manage)
# └─────────────────────────────────────────────────────────────────────────────

# Convex — database + crons + workflows + vector search
# Run: bunx convex dev (creates project, prints URL)
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
# Better Auth currently expects this server-side alias as well.
# Set it to the same value as NEXT_PUBLIC_CONVEX_SITE_URL.
CONVEX_SITE_URL=
CONVEX_DEPLOYMENT=

# Better Auth / application origin
SITE_URL=http://localhost:3000

# Admin allowlist for protected onboarding + operator surfaces
# Use a comma-separated list of emails and/or domains
RC_ADMIN_EMAILS=
RC_ADMIN_DOMAINS=

# Anthropic — LLM for chat, panel console, content generation
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Voyage AI — embeddings for RAG (voyage-3-lite, 512d, free 200M tokens)
# Get key: https://dash.voyageai.com/
VOYAGE_API_KEY=

# DataForSEO — keyword research, SERP analysis, experiment baselines
# Get credentials: https://app.dataforseo.com/api-dashboard
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Typefully — multi-platform social distribution (X, LinkedIn, Threads, Bluesky, Mastodon)
# Get key: https://typefully.com/settings/api
TYPEFULLY_API_KEY=
TYPEFULLY_SOCIAL_SET_ID=

# GrowthRat's GitHub account — content backup, community engagement
# Create token: https://github.com/settings/tokens (scopes: gist, public_repo)
GITHUB_TOKEN=
GITHUB_OWNER=kirso
GITHUB_CONTENT_REPO=growthcat

# ┌─────────────────────────────────────────────────────────────────────────────
# │ SLACK (operator configures the Slack app)
# └─────────────────────────────────────────────────────────────────────────────

# Slack bot token (from Slack app settings > OAuth & Permissions)
SLACK_BOT_TOKEN=

# Slack signing secret (from Slack app settings > Basic Information)
SLACK_SIGNING_SECRET=

# Default Slack channel for reports/approvals
SLACK_DEFAULT_CHANNEL=growthrat

# ┌─────────────────────────────────────────────────────────────────────────────
# │ REVENUECAT CONNECTS (they provide via /onboarding, stored in Convex)
# │ These are NOT in .env.local — RC enters them in the onboarding UI
# │ and they're stored server-side in Convex, never seen by the operator.
# └─────────────────────────────────────────────────────────────────────────────
#
# RC_SLACK_BOT_TOKEN    → RC adds GrowthRat bot to their Slack workspace
# RC_CMS_API_KEY        → RC provides blog CMS access
# RC_CHARTS_API_KEY     → RC provides Charts/analytics access (if available)
# RC_GITHUB_ORG         → RC adds GrowthRat to their GitHub org
# RC_REPORT_CHANNEL     → RC chooses which Slack channel for reports
# RC_REVIEW_MODE        → RC chooses: draft-only or auto-publish
# RC_FOCUS_TOPICS       → RC sets initial topic priorities
#
# These are entered at: /onboarding (post-hire)
# ─────────────────────────────────────────────────────────────────────────────

# ┌─────────────────────────────────────────────────────────────────────────────
# │ OPTIONAL
# └─────────────────────────────────────────────────────────────────────────────

# OpenAI fallback (only if Anthropic unavailable)
# OPENAI_API_KEY=

# Convex production deploy (CI/CD only)
# CONVEX_DEPLOY_KEY=
